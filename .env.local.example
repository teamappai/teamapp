# ─────────────────────────────────────────────────────────────────────────────
# TeamApp environment variables
#
# Copy this file to `.env.local` and fill in real values:
#     cp .env.local.example .env.local
#
# `.env.local` is git-ignored. Variables prefixed with NEXT_PUBLIC_ are exposed
# to the browser — never put secrets behind that prefix. Not every variable is
# needed in Phase 0; later phases (auth, billing, email, AI) consume the rest.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Phase 0+) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-only. Bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Analytics: PostHog (later phase) ─────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-only. Personal API Key (phx_…), scoped to feature_flag:read — used for
# server-side feature-flag evaluation only. Never expose to the browser.
POSTHOG_PERSONAL_API_KEY=phx_your_posthog_personal_api_key

# ── Billing: Stripe (Phase 12) ───────────────────────────────────────────────
# Server-only secrets (never NEXT_PUBLIC_):
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# Stripe Price IDs (one per plan × cycle, plus the per-seat add-on prices).
# Enterprise is sales-managed and needs no price ID.
STRIPE_PRICE_LAUNCH_MONTHLY=price_xxx
STRIPE_PRICE_LAUNCH_ANNUAL=price_xxx
STRIPE_PRICE_LAUNCH_EXTRA_SEAT=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_PRO_EXTRA_SEAT=price_xxx
# Client-accessible (safe to expose):
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Email: Resend (later phase) ──────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ── AI providers (later phase) ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000

# ── Error monitoring: Sentry (Phase 16B) ─────────────────────────────────────
# DSN is public (safe to expose); it tells the SDK where to send events.
NEXT_PUBLIC_SENTRY_DSN=https://your_public_key@oXXXX.ingest.us.sentry.io/XXXX
# Server-only auth token, used ONLY at build time to upload source maps.
SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token
# Org + project slugs are REQUIRED for build-time source-map upload (the DSN
# alone can't be turned into upload targets). Without these, the build still
# succeeds — source-map upload is simply skipped.
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
# Optional tuning:
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
